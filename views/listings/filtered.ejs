<% layout("layouts/boilerplate") -%>
 <div class="filters-wrapper">
      <div id="filters">
        <div class="filter">
          <div>
            <a href="/listings/category/room">
              <i class="fa-solid fa-bed"></i>
            </a>
          </div>
          <p>Rooms</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/farms">
              <i class="fa-solid fa-tractor"></i>
            </a>
          </div>
          <p>Farms</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/mountain">
              <i class="fa-solid fa-mountain"></i>
            </a>
          </div>
          <p>Mountains</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/Towers">
              <i class="fa-solid fa-tower-observation"></i>
            </a>
          </div>
          <p>Towers</p>
        </div>

        <div class="filter">
          <div>
            <a href="/listings/category/windmills">
              <i class="fa-solid fa-fan"></i>
            </a>
          </div>
          <p>Windmills</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/park">
              <i class="fa-solid fa-tree"></i>
            </a>
          </div>
          <p>National-Parks</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/artic">
              <i class="fa-solid fa-snowflake"></i>
            </a>
          </div>
          <p>Arctic</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/tyhome">
              <i class="fa-solid fa-house"></i>
            </a>
          </div>
          <p>Tiny Homes</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/urban">
              <i class="fa-solid fa-city"></i>
            </a>
          </div>
          <p>Urban</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/castle">
              <i class="fa-solid fa-chess-rook"></i>
            </a>
          </div>
          <p>Castles</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/beach">
              <i class="fa-solid fa-umbrella-beach"></i>
            </a>
          </div>
          <p>Beach</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/camping">
              <i class="fa-solid fa-fire"></i>
            </a>
          </div>
          <p>Camping</p>
        </div>
        <div class="filter">
          <div>
            <a href="/listings/category/countryside">
              <i class="fa-solid fa-seedling"></i>
            </a>
          </div>
          <p>Countryside</p>
        </div>
      </div>
       <div class="tax-toggle" id="wq">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" id="checkout">
        <label class="form-check-label" for="flexSwitchCheckDefault">
          <span class="badge text-bg-warning">Display Total Taxes</span>
        </label>
      </div>
    </div>
    </div>
<% if (allListings.length === 0) { %>
  <div class="text-center my-5">
    <h4 class="fw-semibold">No listings found in <%= title %> category.</h4>
    <a href="/listings/new" class="btn btn-outline-danger mt-3 px-4 py-2">Airbnb your Home</a>
  </div>
<% } else { %>

  <h2 class="mb-4 fw-bold text-capitalize"><%= title %> Stays</h2>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
    <% for (let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
          <div class="card h-100 shadow-sm border-0 listing-card position-relative overflow-hidden transition">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" style="height: 18rem; object-fit: cover; border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
            
            <div class="card-img-overlay d-flex justify-content-between align-items-start p-3">
              <button class="guest-fav-btn">Guest favorite</button>
              <div class="wishlist-icon">
                <i class="fa-regular fa-heart"></i>
              </div>
            </div>

            <div class="card-body">
              <h5 class="card-title fw-semibold mb-1"><%= listing.title %></h5>
              <p class="card-text mb-0 text-muted">
                &#8377; <%= listing.price.toLocaleString("en-IN") %> <span class="text-secondary">/ night</span>
              </p>
              <small class="text-muted tax-info">+18% GST</small>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

<% } %>
 <script>
 let taxswitch = document.getElementById("checkout");
taxswitch.addEventListener("click", () => {
  let taxInfo = document.getElementsByClassName("tax-info");
  for (let info of taxInfo) {
    if (info.style.display === "inline") {
      info.style.display = "none";
    } else {
      info.style.display = "inline";
    }
  }
});
 </script>